# 飞书应用配置
APP_ID=your_app_id
APP_SECRET=your_app_secret

# ARK 方舟大模型配置
ARK_API_KEY=your_ark_api_key
ARK_MODEL=your_ark_endpoint_id
ARK_BASE_URL=https://ark-cn-beijing.bytedance.net/api/v3

# 沙箱配置
SANDBOX_TIMEOUT=30
SANDBOX_MAX_OUTPUT_LENGTH=4000

# Coco 配置
COCO_EXECUTION_TIMEOUT=7200
COCO_SESSION_TIMEOUT=86400
COCO_MAX_OUTPUT_LENGTH=30000

# 流式输出配置
STREAMING_ENABLED=true

# 消息回复模式
# direct: 直接回复（消息显示在被回复消息下方）
# thread: 话题回复（消息显示在独立话题区域，更整洁）
# SMART_REPLY_MODE 控制智能模式，DEFAULT_REPLY_MODE 控制编程/Deep/Loop等模式
SMART_REPLY_MODE=direct
DEFAULT_REPLY_MODE=thread
