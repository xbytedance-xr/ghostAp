# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  🚀 快速开始（必填）— 大多数部署者只需修改这些                              ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ── 飞书应用配置 ──
# 默认: 无 | 范围: 必填 | 飞书开放平台 App ID
APP_ID=your_app_id
# 默认: 无 | 范围: 必填 | 飞书 App Secret，同时用于卡片按钮 HMAC 签名
APP_SECRET=your_app_secret

# ── 默认 ACP 工具 ──
# 默认: 空 | 范围: coco/claude/aiden/codex/gemini | 智能模式下未匹配的消息转发到此工具
# 留空则所有未匹配消息作为 Shell 命令执行
DEFAULT_ACP_TOOL=coco

# ── 管理员 ──
# 默认: 空 | 范围: 逗号分隔 open_id | Bot 管理员列表，用于 /lock /unlock 和强制释放
# 获取方式（任选其一）:
#   1. 启动 Bot 后在任意群/私聊发一条消息，查看控制台日志 sender_id 字段
#   2. 私聊 Bot 发送 /status，返回卡片中会显示你的 open_id
#   3. 飞书管理后台 → 通讯录 → 成员详情页复制 open_id
ADMIN_USER_IDS=

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  ⚙️ 常用配置                                                                  ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ── 沙箱配置 ──
# 默认: 30 | 范围: > 0 | Shell 命令执行超时秒数
SANDBOX_TIMEOUT=30
# 默认: 4000 | 范围: > 0 | Shell 输出最大字符数
SANDBOX_MAX_OUTPUT_LENGTH=4000
# 默认: false | 范围: true/false | 启用白名单模式（否则使用黑名单模式）
SANDBOX_USE_WHITELIST=false
# 默认: ls,cd,pwd,echo,cat,git | 范围: 逗号分隔命令 | 白名单模式下允许的命令
SANDBOX_COMMAND_WHITELIST=ls,cd,pwd,echo,cat,git

# ── Coco 配置 ──
# 默认: 7200 | 范围: > 0 | Coco 执行超时秒数
COCO_EXECUTION_TIMEOUT=7200
# 默认: 86400 | 范围: > 0 | Coco 会话超时秒数
COCO_SESSION_TIMEOUT=86400
# 默认: 30000 | 范围: > 0 | Coco 输出最大字符数
COCO_MAX_OUTPUT_LENGTH=30000

# ── 流式输出配置 ──
# 默认: true | 范围: true/false | 是否启用流式卡片输出
STREAMING_ENABLED=true

# ── TTADK 配置 ──
# 默认: coco | 范围: coco/claude/cursor/gemini/codex/tmates/trae/opencode | 默认 AI 工具
TTADK_DEFAULT_TOOL=claude
# 默认: 空 | 范围: 模型名称 | 默认模型（留空使用工具默认）
TTADK_DEFAULT_MODEL=

# ── 消息回复模式 ──
# 默认: direct | 范围: direct/thread | 智能模式回复方式
SMART_REPLY_MODE=direct
# 默认: thread | 范围: direct/thread | 编程/Deep/Spec/Worktree 等模式回复方式
DEFAULT_REPLY_MODE=thread

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  🔧 高级配置（一般无需修改）— 除非遇到超时问题，否则保持默认值              ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ── 多群隔离与锁机制 ──
# 默认: 300 | 范围: > 0 | 仓库空闲多少秒后自动释放锁，让其他群可以操作该仓库
REPO_LOCK_IDLE_TIMEOUT=300
# 默认: 3600 | 范围: > 0 | 仓库锁最大持有秒数，超时后系统强制释放（防止异常挂起）
REPO_LOCK_HARD_TIMEOUT=3600
# 默认: 50 | 范围: >= 1 | 每个项目最多同时被多少个群使用，超出后最久未使用的群会被自动移除
MAX_ALLOWED_CHAT_IDS=50
# 默认: 200 | 范围: > 0 | 被驱逐群 ID 缓存上限（用于驱逐通知去重）
MAX_EVICTED_CACHE=200
# 默认: false | 范围: true/false | 设为 true 时仓库冲突会直接拒绝命令并通知用户（而非静默等待）
SANDBOX_STRICT_LOCK_MODE=false
# 默认: 86400 | 范围: > 0 | 管理员锁定群聊后，最长持续多少秒自动解锁（默认 24 小时）
CHAT_LOCK_MAX_DURATION=86400
# 默认: 60 | 范围: > 0 | 仓库锁清理线程扫描间隔秒数
REPO_LOCK_CLEANUP_INTERVAL=60
# 默认: 60 | 范围: > 0 | 群锁清理线程扫描间隔秒数
CHAT_LOCK_CLEANUP_INTERVAL=60
# 默认: 300 | 范围: 60-600，必须为 60 的整数倍 | /lock 后可撤销的窗口时长秒数（窗口内显示"撤销"按钮）
# LOCK_UNDO_WINDOW_SECONDS=300
# 默认: 120 | 范围: > 0 | /lock 确认卡片有效期秒数，超时后确认按钮失效
LOCK_CONFIRM_TIMEOUT=120

# ── 项目专属群 ──
# 默认: dev | /new-chat 创建群时的名称后缀，群名格式为 "{项目名}-{后缀}"
PROJECT_CHAT_SUFFIX=ghostAp

# ── Spec Engine 执行轮次 ──
# 默认: 1000 | 范围: 1-5000 | Spec 最大迭代轮数，到达后暂停并提示可恢复/调大
# 场景: 长程 Spec 任务需要更多闭环迭代时可调大，想更快停住可调小
SPEC_MAX_CYCLES=1000

# ── Spec Engine 审查超时与重试 ──
# 默认: 240 | 范围: > 0，且 >= SPEC_REVIEW_MIN_TIMEOUT | 单视角审查超时秒数
# 场景: 若审查频繁超时可适当调大
SPEC_REVIEW_TIMEOUT=240
# 默认: 60 | 范围: > 0，且 >= SPEC_REVIEW_HARD_FLOOR | 自适应超时下限秒数
SPEC_REVIEW_MIN_TIMEOUT=60
# 默认: 20 | 范围: > 0 | 自适应超时绝对下限秒数
SPEC_REVIEW_HARD_FLOOR=20
# 默认: 3 | 范围: 1-20 | 并行 worker 数量上限
SPEC_REVIEW_MAX_PARALLEL=3
# 默认: 30 | 范围: > 0 | 重试前等待的最大延迟秒数
# 场景: 若希望重试间隔更短可调小
SPEC_REVIEW_RETRY_MAX_DELAY=30
# 默认: 2 | 范围: 0-10 | 单轮最大重试次数
# 场景: 设为 0 可完全禁用自动重试
SPEC_REVIEW_RETRY_MAX_ATTEMPTS=2
# 默认: 8.0 | 范围: > 0 | 重试退避的基础延迟秒数
SPEC_REVIEW_RETRY_BASE_DELAY=8.0
# 默认: 1.5 | 范围: > 1.0 | 重试退避的衰减因子（越大退避越快）
SPEC_REVIEW_RETRY_DECAY_FACTOR=1.5
# 默认: fail | 范围: pass/fail | 审查结果解析失败时的默认判定（fail=不通过，pass=通过）
SPEC_REVIEW_PARSE_FAILURE_DEFAULT=fail

# ── 熔断器配置 ──
# 默认: true | 范围: true/false | 是否启用连续失败熔断
SPEC_REVIEW_FAILURE_CIRCUIT_ENABLED=true
# 默认: 4 | 范围: >= 1 | 连续失败触发熔断的次数
SPEC_REVIEW_FAILURE_MAX_CONSECUTIVE=4
# 默认: 2 | 范围: >= 0 | 熔断后跳过的周期数（指数增长）
SPEC_REVIEW_FAILURE_COOLDOWN_CYCLES=2
# 默认: 12 | 范围: >= 1 | 熔断跳过周期的最大上限
SPEC_REVIEW_FAILURE_MAX_COOLDOWN_CYCLES=12

# ── Card Session 卡片配置 ── # since v0.9
# 绝大多数用户无需修改此区域，所有参数均已内置合理默认值。
# 完整参数列表请运行: uv run python -m src.main --validate
#
# ── 会话超时 ──
# 仅需调节以下两项即可满足绝大多数部署场景。
#
# 默认: 1800 | 范围: 300-7200 | 用户会话空闲超时(秒)，超时后卡片显示关闭提示及重启命令
# 场景: 若您的团队会话频繁超时中断，可适当调大此值
# CARD_SESSION_IDLE_TIMEOUT=1800
# 默认: 300 | 范围: 60-3600 | 超时前提前提醒时间(秒)，到时会弹出续期按钮
# 场景: 若用户反馈续期提示太晚来不及操作，可适当调大此值
# CARD_SESSION_IDLE_WARN_AT_REMAINING=300
#
# ── 锁定参数 ──
# 默认: 300 | 范围: 60-600，必须为 60 的整数倍 | /lock 后可撤销的窗口时长秒数
# 场景: 需要更长的撤销窗口时可适当调大（最大 10 分钟）
# LOCK_UNDO_WINDOW_SECONDS=300
#
# ── 高级参数 ──
# 以下参数面向高级运维场景（高并发群聊、大规模多群部署），一般保持默认即可。
#
# 默认: 4 | 范围: 1-32 | 卡片投递线程池最大工作线程数，控制并发 Feishu API 调用数
# 场景: 高并发群聊（>50人同时触发任务）出现卡片更新延迟时，可适当调大
# CARD_DELIVERY_POOL_MAX_WORKERS=4
# 默认: 28000 | 范围: 1000-50000 | 单张卡片最大字符数（characters），超出自动截断
# 场景: 若长输出被截断且需完整展示，可调大；注意飞书卡片有最大包体限制
# CARD_MAX_CHARS=28000
# 默认: 600 | 范围: 60-3600 | 会话锁生存时间（秒，约 1-60 分钟）
# 场景: 长时间运行任务（如大型 spec 循环）锁过早释放时，可适当调大
# CARD_SESSION_LOCK_TTL=600
# 默认: 10000 | 范围: 1000-100000 | 同时活跃的卡片会话上限，超出时自动回收闲置会话锁
# 场景: 大规模部署（多群+高频任务）出现容量告警时调大
# CARD_SESSION_LOCK_MAX=10000

# 默认: true | 启用多步任务独立飞书卡片展示（每个子任务一张卡片）
# 关闭后退化为单卡模式，所有内容渲染在同一张卡片中
# 注意: CARD_MAX_TASK_CARDS 仅在本项为 true 时生效
# CARD_TASK_LEVEL_CARDS_ENABLED=true

# 默认: 8 | 范围: 1~20 | 多步任务模式下最大卡片数量，超出合并到最后一张卡片
# 前提: 需 CARD_TASK_LEVEL_CARDS_ENABLED=true
# 场景: 子任务多时消息刷屏可调小；需独立查看每个任务细节时调大
# CARD_MAX_TASK_CARDS=8
