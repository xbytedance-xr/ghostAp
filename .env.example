# 飞书应用配置
APP_ID=your_app_id
# 同时用于卡片按钮 HMAC 签名，变更此值将使已发出的重试按钮立即失效
# 签名兼容窗口由 SIG_COMPAT_DEPLOY_DATE / SIG_COMPAT_WINDOW_DAYS 控制（见下方）
APP_SECRET=your_app_secret

# ARK 方舟大模型配置
ARK_API_KEY=your_ark_api_key
ARK_MODEL=your_ark_endpoint_id
ARK_BASE_URL=https://ark-cn-beijing.bytedance.net/api/v3

# 沙箱配置
SANDBOX_TIMEOUT=30
SANDBOX_MAX_OUTPUT_LENGTH=4000
# 白名单模式（默认 false：使用黑名单模式）
SANDBOX_USE_WHITELIST=false
# 白名单命令列表（逗号分隔，仅在白名单模式启用时生效）
SANDBOX_COMMAND_WHITELIST=ls,cd,pwd,echo,cat,git

# Coco 配置
COCO_EXECUTION_TIMEOUT=7200
COCO_SESSION_TIMEOUT=86400
COCO_MAX_OUTPUT_LENGTH=30000

# 流式输出配置
STREAMING_ENABLED=true

# TTADK 配置
TTADK_DEFAULT_TOOL=coco
TTADK_DEFAULT_MODEL=

# 消息回复模式
# direct: 直接回复（消息显示在被回复消息下方）
# thread: 话题回复（消息显示在独立话题区域，更整洁）
# SMART_REPLY_MODE 控制智能模式，DEFAULT_REPLY_MODE 控制编程/Deep/Loop等模式
SMART_REPLY_MODE=direct
DEFAULT_REPLY_MODE=thread

# 多群隔离与锁机制
# 管理员用户 ID 列表（飞书 open_id，逗号分隔），用于 /lock /unlock 和仓库锁强制释放权限
# 获取步骤:
#   1. 飞书管理后台 → 通讯录 → 搜索用户 → 复制 open_id（ou_ 前缀）
#   2. 或查看 Bot 日志中 sender_id 字段（每条消息均带 open_id）
#   3. 或在私聊中向 Bot 发送 /status，日志会打印当前用户 open_id
# 示例: ADMIN_USER_IDS=ou_abc123,ou_def456
ADMIN_USER_IDS=
# 仓库锁空闲超时（秒），超时自动释放（默认 300，必须 > 0）
REPO_LOCK_IDLE_TIMEOUT=300
# 仓库锁清理线程扫描间隔（秒）（默认 60，必须 > 0）
REPO_LOCK_CLEANUP_INTERVAL=60
# 仓库锁最大持有时长（秒），超时后系统自动强制释放（默认 3600，必须 > 0）
REPO_LOCK_HARD_TIMEOUT=3600
# 每个项目最多关联的群聊数量（LRU 淘汰，默认 50）
# 超过上限时，最久未使用的群会被自动解绑并收到通知卡片
MAX_ALLOWED_CHAT_IDS=50
# 锁相关确认操作（如强制释放）的有效期（秒），超时后确认按钮失效（默认 120）
LOCK_CONFIRM_TIMEOUT=120
# 锁后端实现，目前仅支持 memory（纯内存单进程），未来可扩展
LOCK_BACKEND=memory
# SandboxExecutor 严格锁模式 — true 时锁冲突直接报错，false 仅 warning（默认 false，生产环境推荐设为 true）
SANDBOX_STRICT_LOCK_MODE=false
# 群锁最大持续时间（秒），超时自动释放（默认 86400 = 24h，必须 > 0）
CHAT_LOCK_MAX_DURATION=86400
# 群锁清理线程扫描间隔（秒）（默认 60，必须 > 0）
CHAT_LOCK_CLEANUP_INTERVAL=60
# 项目 evicted_chat_ids 有界 LRU 上限（默认 200）
MAX_EVICTED_CACHE=200
# 签名回退兼容窗口 — 升级后旧按钮使用 plain SHA-256 签名的过渡期
# 部署日期（ISO 格式），回退窗口起点；留空时以进程启动日期为起点（推荐留空）
SIG_COMPAT_DEPLOY_DATE=
# 回退兼容天数，超过后仅接受 HMAC 签名（默认 7）
SIG_COMPAT_WINDOW_DAYS=7
